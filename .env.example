# ============================================================
# ENTORNO
# ============================================================
# Valores: development | production
NODE_ENV=development

# ============================================================
# SERVIDOR
# ============================================================
SERVER_PORT=8787

# ============================================================
# SEGURIDAD — OBLIGATORIO EN PRODUCCIÓN
# ============================================================
# Secreto para firmar tokens JWT de sesión.
# En producción: genera un valor aleatorio fuerte (>= 32 chars).
# Ejemplo: openssl rand -hex 32
JWT_SECRET=a3f8c2e1d4b7a9f0e2c5d8b1a4f7c0e3d6b9a2f5c8e1d4b7a0f3c6e9d2b5a8

# Orígenes permitidos por CORS (separados por coma).
# Solo necesario si el frontend y backend corren en dominios diferentes.
# En desarrollo con el proxy de Vite no es necesario.
# Ejemplo: https://app.hospital.local,https://reportes.hospital.local
# CORS_ORIGIN=

# ============================================================
# CONEXIÓN GENERAL
# ============================================================
# Usada por: Centro Obstétrico, UCCA, UCCP, Lavado de Manos, Exportaciones

SQL_HOST=192.168.32.129
SQL_PORT=1433
SQL_DATABASE=SIGH_DEPURA
SQL_USER=usr_dwdepura
SQL_PASSWORD=usrd3pura
# En producción usar true para encriptar la conexión
SQL_ENCRYPT=false
# En producción usar false para validar el certificado del servidor
SQL_TRUST_CERT=true
SQL_POOL_MAX=10

# ============================================================
# CONEXIÓN SIGH 1
# ============================================================
# Usada por: Monitoreo, Gestión de Citas, Gestión de Camas

SIGH_SQL1_HOST=192.168.32.123
SIGH_SQL1_PORT=1433
SIGH_SQL1_DATABASE=SIGH_EST
SIGH_SQL1_USER=usr_datawh
SIGH_SQL1_PASSWORD=usr_datawh++**1
SIGH_SQL1_ENCRYPT=false
SIGH_SQL1_TRUST_CERT=true
SIGH_SQL1_POOL_MAX=10

# ============================================================
# CONEXIÓN SIGH 2
# ============================================================
# Usada por: Producción de Médicos

SIGH_SQL2_HOST=192.168.32.127
SIGH_SQL2_PORT=1433
SIGH_SQL2_DATABASE=SIGH_EST
SIGH_SQL2_USER=usr_appEst_dashboard
SIGH_SQL2_PASSWORD=usr_appEst_dashboard/*-H$v$5
SIGH_SQL2_ENCRYPT=false
SIGH_SQL2_TRUST_CERT=true
SIGH_SQL2_POOL_MAX=10

# ============================================================
# VITE (frontend, solo desarrollo)
