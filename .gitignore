# ============================================================
# REPORTEADOR 2.0 - GITIGNORE
# Proyecto React/Vite + Node/Express + Apache Windows
# ============================================================


# ============================================================
# Dependencias
# ============================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ============================================================
# Build / archivos generados
# ============================================================
dist/
build/
.vite/


# ============================================================
# Variables de entorno / configuración sensible
# ============================================================
.env
.env.*
!.env.example


# ============================================================
# Logs
# ============================================================
logs/
*.log
server/logs/


# ============================================================
# Certificados SSL / llaves privadas
# NO subir nunca a Git
# ============================================================
*.key
*.pem
*.crt
*.cer
*.csr
*.pfx
*.p12
*.ca-bundle
*ca-bundle*


# ============================================================
# Configuración local de Apache / servidor
# Solo se debe documentar, no subir archivos reales sensibles
# ============================================================
httpd.conf
httpd-vhosts.conf
httpd-ssl.conf
ssl/
certs/
certificados/


# ============================================================
# Archivos temporales / backups
# ============================================================
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*_BACKUP*/
backup/
backups/


# ============================================================
# Sistema operativo Windows
# ============================================================
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk


# ============================================================
# Sistema operativo macOS / Linux
# ============================================================
.DS_Store
.AppleDouble
.LSOverride


# ============================================================
# Editores / IDE
# ============================================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp


# ============================================================
# Testing / coverage
# ============================================================
coverage/
.nyc_output/


# ============================================================
# TypeScript / caches
# ============================================================
*.tsbuildinfo


# ============================================================
# Archivos locales de despliegue
# ============================================================
deploy.local.ps1
deploy.local.bat

# ============================================================
# Informes generados localmente
# ============================================================
informes/

# ============================================================
# Scripts PPR ocasionales de carga/comparacion local
# ============================================================
scripts/ppr-*.mjs

